{
  "name": "flock-backend",
  "version": "1.0.0",
  "description": "Flock — Restaurant Queue & Pre-Order Platform API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio",
    "mcp:setup": "bash scripts/setup-mcp.sh",
    "test:unit": "vitest run --config vitest.config.ts --project unit",
    "test:integration": "vitest run --config vitest.config.ts --project integration",
    "test:contract": "vitest run --config vitest.config.ts --project contract",
    "test:e2e:local": "FLOCK_TEST_URL=${FLOCK_TEST_URL:-http://localhost:3000} npx playwright test tests/e2e.local.spec.ts --project=iPhone-14 --project=Galaxy-S23 --workers=1",
    "test:e2e:prod": "FLOCK_TEST_URL=${FLOCK_TEST_URL:-https://taurant.onrender.com} npx playwright test tests/e2e.prod.spec.ts --project=iPhone-14 --project=Galaxy-S23 --workers=1",
    "test:devtools:prod": "FLOCK_TEST_URL=${FLOCK_TEST_URL:-https://taurant.onrender.com} node scripts/run-devtools-prod-audit.mjs",
    "test:visual": "npx playwright test tests/visual-regression.spec.ts",
    "test:visual:update": "npx playwright test tests/visual-regression.spec.ts --update-snapshots",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:contract"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "razorpay": "^2.9.2",
    "typescript": "^5.4.2",
    "uuid": "^9.0.0",
    "winston": "^3.12.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.28",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.8",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.1.0",
    "node-mocks-http": "^1.17.2",
    "prisma": "^5.10.0",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "vitest": "^4.0.18"
  }
}
