# ── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_VERSION=v1
# Comma-separated list used only in production, for example:
# APP_ALLOWED_ORIGINS="https://flock-pilot.onrender.com,https://pilot.flock.example.com"
APP_ALLOWED_ORIGINS=""

# ── Database ──────────────────────────────────────────
# Local:
# DATABASE_URL="postgresql://flock:password@localhost:5432/flockdb?schema=public"
# Supabase (prefer the session pooler URI from Project Settings -> Database):
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

# ── Redis ─────────────────────────────────────────────
# Optional for the first hosted pilot. Leave blank to run in degraded mode.
REDIS_URL=""
# Local:
# REDIS_URL="redis://localhost:6379"
# For Upstash:
# REDIS_URL="rediss://:password@hostname:port"

# ── Auth ──────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="7d"
GUEST_JWT_EXPIRES_IN="6h"
ONBOARDING_TOKEN="set-an-internal-onboarding-token"
OTP_EXPIRES_SECONDS=300

# ── Razorpay ──────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_test_XXXXXXXXXXXX"
RAZORPAY_KEY_SECRET="XXXXXXXXXXXXXXXXXXXXXXXX"
RAZORPAY_WEBHOOK_SECRET="XXXXXXXXXXXXXXXXXXXXXXXX"
RAZORPAY_ACCOUNT_NUMBER="XXXXXXXXXXXXXXXXXX"

# ── Gupshup (WhatsApp Business API) ───────────────────
GUPSHUP_API_KEY="XXXXXXXXXXXXXXXXXXXXXXXX"
GUPSHUP_APP_NAME="FlockApp"
GUPSHUP_SOURCE_NUMBER="917XXXXXXXXX"

# ── MSG91 (SMS fallback) ──────────────────────────────
MSG91_AUTH_KEY="XXXXXXXXXXXXXXXXXXXXXXXX"
MSG91_SENDER_ID="FLOCK"
MSG91_TEMPLATE_ID_OTP="XXXXXXXXXX"
MSG91_TEMPLATE_ID_QUEUE="XXXXXXXXXX"
MSG91_TEMPLATE_ID_TABLE_READY="XXXXXXXXXX"

# ── ClearTax (GST invoicing) ──────────────────────────
CLEARTAX_API_KEY="XXXXXXXXXXXXXXXXXXXXXXXX"
CLEARTAX_BASE_URL="https://api.cleartax.in/v1"

# ── UrbanPiper (POS integration) ──────────────────────
URBANPIPER_USERNAME="flock_integration"
URBANPIPER_API_KEY="XXXXXXXXXXXXXXXXXXXXXXXX"
URBANPIPER_BASE_URL="https://api.urbanpiper.com/v1"

# ── Feature flags ─────────────────────────────────────
# Hosted smoke-test defaults:
USE_MOCK_PAYMENTS=true
USE_MOCK_NOTIFICATIONS=true
USE_MOCK_GST=true
USE_MOCK_POS=true

# ── TMS polling ───────────────────────────────────────
TMS_POLL_INTERVAL_MS=4000
TABLE_READY_WINDOW_MINUTES=10
